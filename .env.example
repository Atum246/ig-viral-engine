# 🟢 IG VIRAL ENGINE — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub!

# ============================================
# TELEGRAM BOT (Required)
# ============================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (send /start to bot, then check getUpdates)
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# INSTAGRAM GRAPH API (Required for posting)
# ============================================
# From Facebook Developer Console
IG_USER_ID=your_ig_user_id_here
IG_ACCESS_TOKEN=your_ig_access_token_here

# ============================================
# N8N CONFIGURATION
# ============================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=ChangeThisToSomethingSecure!

# ============================================
# SERVER CONFIGURATION
# ============================================
GENERIC_TIMEZONE=Asia/Shanghai
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https

# ============================================
# IMAGE HOSTING (Choose one)
# ============================================
# Option A: Your own server
PUBLIC_URL=http://your-server-ip:8080

# Option B: Cloudinary (free tier)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# AI MODEL (Optional — defaults to Ollama)
# ============================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
